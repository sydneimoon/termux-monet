<?xml version="1.0" encoding="utf-8" ?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_activated="true">
        <layer-list>
            <!-- Icono detrás -->
            <item android:right="16dp">
                <bitmap android:src="@drawable/ic_robot_angry"
                        android:gravity="right|center_vertical"
                        android:tint="#bb323232" />
            </item>

            <!-- Imagen de fondo activado -->
            <item android:drawable="@drawable/current_session" />
        </layer-list>
    </item>

    <item android:state_activated="false" android:drawable="@drawable/session_ripple" />

</selector>

